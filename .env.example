# Telegram Bot Token (обязательно)
# Получить: https://t.me/BotFather → /newbot
BOT_TOKEN=your_telegram_bot_token_here

# SuperJob API Key (рекомендуется)
# Получить: https://api.superjob.ru/ → Зарегистрировать приложение
# Если не указать, SuperJob не будет использоваться
SUPERJOB_API_KEY=

# База данных (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./vacancies.db

# Веб-интерфейс
WEB_HOST=127.0.0.1
WEB_PORT=8000

# Интервал проверки вакансий (в часах)
CHECK_INTERVAL_HOURS=1
